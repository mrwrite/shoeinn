{
  "version": "0.2.0",
  "configurations": [
    
    {
      "name": "ShoeInn API (uvicorn)",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app.main:app",        
        "--host", "0.0.0.0",
        "--port", "8001",
        "--log-level", "debug"
      ],
      "cwd": "${workspaceFolder}/apps/api",
      "env": {
        "PYTHONUNBUFFERED": "1"
      },
      "console": "integratedTerminal",
      "justMyCode": false
    }
  ]
}
